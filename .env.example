# -------------------------------------------------------------
# サイトアクセス・機能制限用
# -------------------------------------------------------------
# サイトの閲覧（/upload 以外）に必要な学内共通の簡易パスワード
SITE_COMMON_PASSWORD=your_common_password_here

# 本番環境のサイトURL（マジックリンクのリダイレクト先に使用）
# ローカル開発時は未設定でも動作するが、Vercel等へのデプロイ時は必ず設定すること
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# -------------------------------------------------------------
# 環境変数: Database / Prisma
# -------------------------------------------------------------
# Supabase Transaction Mode Session pooler URL (Query用)
DATABASE_URL="postgres://[db-user].[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Session Mode URL (Migration用)
DIRECT_URL="postgres://[db-user].[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# -------------------------------------------------------------
# 環境変数: Supabase Client (Next.js / Frontend用)
# -------------------------------------------------------------
# プロジェクトURL
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"

# プロジェクト Anon Key
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
